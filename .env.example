# Environment Configuration Example
PORT=5000
NODE_ENV=development

# AI Bill Parser Settings
# Supported providers: openai, gemini, anthropic
AI_PROVIDER=openai
AI_API_KEY=your_api_key_here

# When DEMO_MODE=true, the app uses pre-defined receipt fixtures for offline/free-tier testing.
DEMO_MODE=true

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your-google-client-id-here.apps.googleusercontent.com

# PostgreSQL Database connection URL (for production/Vercel)
DATABASE_URL=postgresql://username:password@localhost:5432/ecotrack

# Session signing key
JWT_SECRET=your_jwt_secret_here
